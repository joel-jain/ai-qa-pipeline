{
  "name": "ai-qa-pipeline",
  "version": "1.0.0",
  "description": "AI-assisted QA pipeline with Jest and PR review automation",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand",
    "test:report": "jest --ci --runInBand --json --outputFile=test-results.json",
    "ai:review": "node scripts/ai-review.js"
  },
  "dependencies": {
    "openai": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ]
  }
}
